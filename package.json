{
  "name": "2bn-selections",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "packages/shared",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "vite",
    "dev:api": "npm run dev --workspace=@2bn/server",
    "build": "npm run build --workspace=@2bn/shared && npm run build --workspace=@2bn/server && tsc -b && vite build",
    "build:web": "tsc -b && vite build",
    "build:api": "npm run build --workspace=@2bn/shared && npm run build --workspace=@2bn/server",
    "start:api": "npm run start --workspace=@2bn/server",
    "seed": "npm run seed --workspace=@2bn/server",
    "db:clean": "npm run db:clean --workspace=@2bn/server",
    "test:mongo": "npm run test:mongo --workspace=@2bn/server",
    "preview": "vite preview"
  },
  "dependencies": {
    "@2bn/shared": "*",
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@heroui/react": "^3.1.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@supabase/supabase-js": "^2.106.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.14",
    "@types/nodemailer": "^8.0.0",
    "@types/react-signature-canvas": "^1.0.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.40.0",
    "fuse.js": "^7.4.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^1.23.0",
    "nodemailer": "^8.0.10",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-dropzone": "^15.0.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.6.2",
    "react-signature-canvas": "^1.1.0-alpha.2",
    "recharts": "^3.8.1",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.1.2",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
