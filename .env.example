# MongoDB Atlas — prefer STANDARD string on Windows if mongodb+srv fails with querySrv ECONNREFUSED
# Atlas → Connect → Drivers → copy "Standard connection string" (starts with mongodb:// not mongodb+srv://)
MONGODB_URI=mongodb://USER:PASSWORD@cluster-shard-00-00.xxxxx.mongodb.net:27017,cluster-shard-00-01.xxxxx.mongodb.net:27017,cluster-shard-00-02.xxxxx.mongodb.net:27017/2bn-selections?ssl=true&replicaSet=atlas-xxxxx-shard-0&authSource=admin&retryWrites=true&w=majority

# Optional fallback URI if you keep SRV as primary
# MONGODB_URI_STANDARD=mongodb://...

# JWT secret — use a long random string in production
JWT_SECRET="change-me-to-a-secure-random-string-at-least-32-chars"

# API server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
WEB_ORIGIN=http://localhost:5173
UPLOADS_DIR=./uploads

# Seed users (first run: npm run seed)
SEED_ADMIN_EMAIL=admin@stepron.com
SEED_ADMIN_PASSWORD=2BN-Admin-2026!
SEED_CLIENT_EMAIL=client@2bncontracting.com
SEED_CLIENT_PASSWORD=2BN-Client-2026!

# Change order minimum (USD)
CHANGE_ORDER_MINIMUM=500

# SMTP (optional in dev — emails log to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@2bncontracting.com

# Frontend (Vite)
VITE_API_URL=http://localhost:3001
